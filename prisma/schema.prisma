generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  User                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  createdById String
  User        User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model PurchaseRequestPO {
  id            Int      @id @default(autoincrement())
  prDocEntry    Int
  prNo          Int
  prDate        DateTime
  prDueDate     DateTime
  seriesName    String?
  prRequester   String?
  prDepartment  String?
  prJobName     String?
  prRemarks     String?
  prStatus      String
  poNo          Int?
  poDescription String?
  poQuantity    Decimal? @db.Decimal(19, 6)
  poUnit        String?
  poLineNum     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([poNo])
  @@index([prDate])
  @@index([prDocEntry])
  @@index([prNo])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  userId        String?   @unique
  username      String?   @unique
  password      String?
  role          String?   @default("PR") @db.VarChar(20)
  isActive      Boolean?  @default(true)
  Account       Account[]
  Post          Post[]
  Session       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model password_reset_token {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// Audit Trail - ประวัติการเปลี่ยนแปลงข้อมูลในระบบ
model activity_trail {
  id            Int       @id @default(autoincrement())
  user_id       String?   @db.VarChar(255)
  user_name     String?   @db.VarChar(255)
  ip_address    String?   @db.VarChar(50)
  action        String    @db.VarChar(50)
  table_name    String?   @db.VarChar(100)  // ชื่อ table ที่ถูกแก้ไข
  record_id     String?   @db.VarChar(255)  // ID ของ record ที่ถูกแก้ไข
  old_values    Json?                        // ค่าก่อนแก้ไข
  new_values    Json?                        // ค่าหลังแก้ไข
  description   String?
  pr_no         Int?
  po_no         Int?
  tracking_id   Int?
  metadata      Json?
  admin_note    String?                      // หมายเหตุจาก admin
  created_at    DateTime? @default(dbgenerated("((CURRENT_TIMESTAMP AT TIME ZONE 'UTC'::text) AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamp(6)
  computer_name String?   @db.VarChar(255)

  @@index([action], map: "idx_activity_trail_action")
  @@index([table_name], map: "idx_activity_trail_table_name")
  @@index([computer_name], map: "idx_activity_trail_computer_name")
  @@index([created_at(sort: Desc)], map: "idx_activity_trail_created_at")
  @@index([po_no], map: "idx_activity_trail_po_no")
  @@index([pr_no], map: "idx_activity_trail_pr_no")
  @@index([user_id], map: "idx_activity_trail_user_id")
}

model ocr_approver {
  id               Int      @id @default(autoincrement())
  ocrCodeId        Int
  userProductionId String
  approverType     String   @db.VarChar(20)
  priority         Int      @default(1)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @db.Timestamp(6)
  createdBy        String?  @db.VarChar(255)

  @@unique([ocrCodeId, userProductionId, approverType])
  @@index([approverType])
  @@index([ocrCodeId])
  @@index([userProductionId])
}

model ocr_code_and_name {
  id                   Int       @id @default(autoincrement())
  code                 Int       @unique
  name                 String    @unique
  remarks              String?
