/// PR Document Receipt - เก็บข้อมูลการรับเอกสาร PR ล่าสุด
model pr_document_receipt {
  id                     Int       @id @default(autoincrement())
  pr_doc_num             Int       @unique
  receipt_date           DateTime  @db.Date
  receipt_datetime       DateTime? @db.Timestamp(6)  // วันเวลาที่กดยืนยัน (เวลาไทย)
  received_by            String    @db.VarChar(255)
  received_by_user_id    String?   @db.VarChar(255)
  ocr_code2              String?   @db.VarChar(50)   // OCR Code2 ที่ใช้ดึงผู้อนุมัติ
  line_approvers         Json?                        // ผู้อนุมัติตามสายงาน (snapshot)
  cost_center_approvers  Json?                        // ผู้อนุมัติตาม Cost Center (snapshot)
  // Individual approval tracking
  // ผู้ขอซื้อ approval (ใครก็ได้สามารถ approve ได้)
  requester_approval_by            String?   @db.VarChar(255)  // ชื่อผู้อนุมัติ (ผู้ขอซื้อ)
  requester_approval_by_user_id    String?   @db.VarChar(255)  // User ID ผู้อนุมัติ (ผู้ขอซื้อ)
  requester_approval_at            DateTime? @db.Timestamp(6)  // วันเวลาที่อนุมัติ (ผู้ขอซื้อ)
  // ผู้อนุมัติตามสายงาน (มีกำหนดผู้อนุมัติที่แน่นอน)
  line_approval_by            String?   @db.VarChar(255)  // ชื่อผู้อนุมัติตามสายงาน
  line_approval_by_user_id    String?   @db.VarChar(255)  // User ID ผู้อนุมัติตามสายงาน
  line_approval_at            DateTime? @db.Timestamp(6)  // วันเวลาที่อนุมัติตามสายงาน
  // ผู้อนุมัติตาม Cost Center (มีกำหนดผู้อนุมัติที่แน่นอน)
  cost_center_approval_by          String?   @db.VarChar(255)  // ชื่อผู้อนุมัติตาม Cost Center
  cost_center_approval_by_user_id  String?   @db.VarChar(255)  // User ID ผู้อนุมัติตาม Cost Center
  cost_center_approval_at          DateTime? @db.Timestamp(6)  // วันเวลาที่อนุมัติตาม Cost Center
  // งานจัดซื้อพัสดุ (เฉพาะ role Manager)
  procurement_approval_by          String?   @db.VarChar(255)  // ชื่อผู้อนุมัติ (งานจัดซื้อพัสดุ)
  procurement_approval_by_user_id  String?   @db.VarChar(255)  // User ID ผู้อนุมัติ (งานจัดซื้อพัสดุ)
  procurement_approval_at          DateTime? @db.Timestamp(6)  // วันเวลาที่อนุมัติ (งานจัดซื้อพัสดุ)
  // VP-C (เฉพาะ role Approval)
  vpc_approval_by                  String?   @db.VarChar(255)  // ชื่อผู้อนุมัติ (VP-C)
  vpc_approval_by_user_id          String?   @db.VarChar(255)  // User ID ผู้อนุมัติ (VP-C)
  vpc_approval_at                  DateTime? @db.Timestamp(6)  // วันเวลาที่อนุมัติ (VP-C)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  updated_at             DateTime? @default(now()) @db.Timestamp(6)

  @@index([pr_doc_num], map: "idx_pr_document_receipt_pr_doc_num")
  @@index([receipt_date], map: "idx_pr_document_receipt_receipt_date")
  @@index([received_by_user_id], map: "idx_pr_document_receipt_user_id")
}

/// PR Document Receipt History - เก็บประวัติการแก้ไขวันที่รับเอกสาร (Audit Trail)
model pr_document_receipt_history {
  id                  Int       @id @default(autoincrement())
