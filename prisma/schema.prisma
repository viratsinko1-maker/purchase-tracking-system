generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  userId        String?   @unique
  username      String?   @unique
  password      String?
  role          String?   @default("PR") @db.VarChar(20)
  isActive      Boolean?  @default(true)
  accounts      Account[]
  posts         Post[]
  sessions      Session[]
}

/// User Production - ดึงจาก TMK_PDPJ01.User
model User_production {
  id             String    @id @default(cuid())
  email          String    @unique  // email จาก TMK_PDPJ01 (ใช้เป็น key)
  userId         String?   @unique  // = email (สำหรับ login)
  username       String?             // = name จาก TMK_PDPJ01 (สำหรับแสดงผล)
  name           String?             // ชื่อเต็มจาก TMK_PDPJ01
  password       String?             // default "1234" (hashed)
  role           String    @default("PR") @db.VarChar(20)
  isActive       Boolean   @default(true)
  sourceId       String?             // original id จาก TMK_PDPJ01
  telegramChatId String?             // Telegram Chat ID สำหรับแจ้งเตือนโดยตรง
  lastSyncAt     DateTime? @db.Timestamp(6)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @db.Timestamp(6)

  @@index([email])
  @@index([isActive])
  @@map("user_production")
}

/// OCR Code and Name - ดึงจาก TMK_PRD.OUDP (Department/Cost Center)
model OCR_codeandName {
  id                   Int       @id @default(autoincrement())
  code                 Int       @unique  // Code จาก OUDP (primary key ใน SAP)
  name                 String    @unique  // Name จาก OUDP (ocr_code2 ใน pr_lines)
  remarks              String?             // ชื่อหน่วยงาน/แผนก
  father               Int?                // รหัส parent (สำหรับ hierarchy)
  lineApproverId       String?             // ผู้อนุมัติตามสายงาน (FK -> User_production.id)
  costCenterApproverId String?             // ผู้อนุมัติตาม Cost Center (FK -> User_production.id)
  lastSyncAt           DateTime? @db.Timestamp(6)
  createdAt            DateTime  @default(now()) @db.Timestamp(6)
  updatedAt            DateTime  @updatedAt @db.Timestamp(6)

  @@index([name])
  @@index([code])
  @@map("ocr_code_and_name")
}

/// OCR User Assignment - เก็บความสัมพันธ์ระหว่าง OCR Code และ User Production
/// สำหรับใช้ในระบบ Approval Workflow ของแต่ละหน่วยงาน
model ocr_user_assignment {
  id              Int       @id @default(autoincrement())
  ocrCodeId       Int                           // FK ไปยัง OCR_codeandName.id
  userProductionId String                        // FK ไปยัง User_production.id
  role            String    @default("member") @db.VarChar(20)  // member, approver, head
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  createdBy       String?   @db.VarChar(255)    // ผู้เพิ่ม

  @@unique([ocrCodeId, userProductionId])
  @@index([ocrCodeId])
  @@index([userProductionId])
}

/// OCR Approver - เก็บผู้อนุมัติหลายคนสำหรับแต่ละ OCR Code
/// approverType: "line" = ผู้อนุมัติตามสายงาน, "cost_center" = ผู้อนุมัติตาม Cost Center
model ocr_approver {
  id              Int       @id @default(autoincrement())
  ocrCodeId       Int                           // FK ไปยัง OCR_codeandName.id
  userProductionId String                        // FK ไปยัง User_production.id
  approverType    String    @db.VarChar(20)     // "line" หรือ "cost_center"
  priority        Int       @default(1)          // ลำดับความสำคัญ (1 = หลัก, 2+ = สำรอง)
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  createdBy       String?   @db.VarChar(255)

  @@unique([ocrCodeId, userProductionId, approverType])
  @@index([ocrCodeId])
  @@index([userProductionId])
  @@index([approverType])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PurchaseRequestPO {
  id            Int      @id @default(autoincrement())
  prDocEntry    Int
  prNo          Int
  prDate        DateTime
  prDueDate     DateTime
  seriesName    String?
  prRequester   String?
  prDepartment  String?
  prJobName     String?
  prRemarks     String?
  prStatus      String
  poNo          Int?
  poDescription String?
  poQuantity    Decimal? @db.Decimal(19, 6)
  poUnit        String?
  poLineNum     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([prDocEntry])
  @@index([prNo])
  @@index([poNo])
  @@index([prDate])
}

