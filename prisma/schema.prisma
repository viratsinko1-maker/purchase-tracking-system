  id               Int       @id @default(autoincrement())
  sync_date        DateTime  @default(now()) @db.Timestamp(6)
  sync_type        String    @db.VarChar(20) // FULL (ล้างข้อมูลเก่า)
  records_synced   Int?      @default(0)
  duration_seconds Decimal?  @db.Decimal(10, 2)
  status           String    @db.VarChar(20) // SUCCESS, FAILED
