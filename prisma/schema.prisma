  received_by_user_id String?   @db.VarChar(255)
  created_at          DateTime? @default(now()) @db.Timestamp(6)

  @@index([pr_doc_num], map: "idx_pr_document_receipt_history_pr_doc_num")
  @@index([action], map: "idx_pr_document_receipt_history_action")
  @@index([created_at(sort: Desc)], map: "idx_pr_document_receipt_history_created_at")
}

/// PR Document Approval - เก็บข้อมูลการอนุมัติเอกสาร PR ล่าสุด
