generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  User                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  createdById String
  User        User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model PurchaseRequestPO {
  id            Int      @id @default(autoincrement())
  prDocEntry    Int
  prNo          Int
  prDate        DateTime
  prDueDate     DateTime
  seriesName    String?
  prRequester   String?
  prDepartment  String?
  prJobName     String?
  prRemarks     String?
  prStatus      String
  poNo          Int?
  poDescription String?
  poQuantity    Decimal? @db.Decimal(19, 6)
  poUnit        String?
  poLineNum     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([poNo])
  @@index([prDate])
  @@index([prDocEntry])
  @@index([prNo])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  userId        String?   @unique
  username      String?   @unique
  password      String?
  role          String?   @default("PR") @db.VarChar(20)
  isActive      Boolean?  @default(true)
  Account       Account[]
  Post          Post[]
  Session       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model activity_trail {
  id            Int       @id @default(autoincrement())
  user_id       String?   @db.VarChar(255)
  user_name     String?   @db.VarChar(255)
  ip_address    String?   @db.VarChar(50)
  action        String    @db.VarChar(50)
  description   String?
  pr_no         Int?
  po_no         Int?
  tracking_id   Int?
  metadata      Json?
  created_at    DateTime? @default(dbgenerated("((CURRENT_TIMESTAMP AT TIME ZONE 'UTC'::text) AT TIME ZONE 'Asia/Bangkok'::text)")) @db.Timestamp(6)
  computer_name String?   @db.VarChar(255)

  @@index([action], map: "idx_activity_trail_action")
  @@index([computer_name], map: "idx_activity_trail_computer_name")
  @@index([created_at(sort: Desc)], map: "idx_activity_trail_created_at")
  @@index([po_no], map: "idx_activity_trail_po_no")
  @@index([pr_no], map: "idx_activity_trail_pr_no")
  @@index([user_id], map: "idx_activity_trail_user_id")
}

model ocr_approver {
  id               Int      @id @default(autoincrement())
  ocrCodeId        Int
  userProductionId String
  approverType     String   @db.VarChar(20)
  priority         Int      @default(1)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @db.Timestamp(6)
  createdBy        String?  @db.VarChar(255)

  @@unique([ocrCodeId, userProductionId, approverType])
  @@index([approverType])
  @@index([ocrCodeId])
  @@index([userProductionId])
}

model ocr_code_and_name {
  id                   Int       @id @default(autoincrement())
  code                 Int       @unique
  name                 String    @unique
  remarks              String?
  father               Int?
  lineApproverId       String?
  costCenterApproverId String?
  lastSyncAt           DateTime? @db.Timestamp(6)
  createdAt            DateTime  @default(now()) @db.Timestamp(6)
  updatedAt            DateTime  @db.Timestamp(6)

  @@index([code])
  @@index([name])
}

model ocr_user_assignment {
  id               Int      @id @default(autoincrement())
  ocrCodeId        Int
  userProductionId String
  role             String   @default("member") @db.VarChar(20)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @db.Timestamp(6)
  createdBy        String?  @db.VarChar(255)

  @@unique([ocrCodeId, userProductionId])
  @@index([ocrCodeId])
  @@index([userProductionId])
}

model po_attachments {
  id               Int       @id @default(autoincrement())
  po_doc_num       Int
  attachment_entry Int
  file_name        String    @db.VarChar(255)
  src_path         String?
  trgt_path        String?
  file_ext         String?   @db.VarChar(50)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  uploaded_date    DateTime? @db.Date

  @@unique([po_doc_num, attachment_entry, file_name])
  @@index([po_doc_num], map: "idx_po_attachments_po_doc_num")
  @@index([po_doc_num])
}

model po_delivery_tracking_log {
  id              Int       @id @default(autoincrement())
  po_doc_num      Int
  delivery_status String    @db.VarChar(20)
  note            String?
  tracked_by      String?   @db.VarChar(255)
  tracked_at      DateTime  @default(now()) @db.Timestamp(6)
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  @@index([po_doc_num])
  @@index([tracked_at])
}

model po_info {
  id          Int       @id @default(autoincrement())
